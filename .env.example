# Copy to .env.local and fill in values

# Required: Claude API key (from console.anthropic.com)
CLAUDE_API_KEY=sk-ant-...

# Required: JWT secret — generate with: openssl rand -hex 32
JWT_SECRET=change-this-to-a-random-secret-at-least-32-chars

# Optional: App URL (defaults to localhost in dev)
NEXT_PUBLIC_APP_URL=https://ullycoffee.com
